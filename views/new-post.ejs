<%- include('partials/header') %>

<div class="page-hero">
  <h1>✍️ Tulis Post Baru</h1>
  <p>Bagikan cerita dan ide Anda dengan dunia.</p>
</div>

<div class="form-container">
  <form action="/posts" method="POST" class="post-form">

    <div class="form-group">
      <label for="title">Judul Post</label>
      <input
        type="text"
        id="title"
        name="title"
        placeholder="Tulis judul yang menarik..."
        required
      />
    </div>

    <div class="form-group">
      <label for="author">Nama Penulis</label>
      <input
        type="text"
        id="author"
        name="author"
        placeholder="Nama Anda"
      />
    </div>

    <div class="form-group">
      <label for="content">Isi Post</label>
      <textarea
        id="content"
        name="content"
        rows="12"
        placeholder="Tulis isi post Anda di sini..."
        required
      ></textarea>
    </div>

    <div class="form-actions">
      <a href="/" class="btn btn-secondary">← Batal</a>
      <button type="submit" class="btn btn-primary">Publikasikan Post →</button>
    </div>

  </form>
</div>

<%- include('partials/footer') %>